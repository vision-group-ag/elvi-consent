<?xml version="1.0" encoding="UTF-8" ?>
<doctrine-mapping
        xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping">
    <entity name="App\Entity\DemoEntity" table="app_demo_entity" repository-class="App\Repository\DemoEntityRepository">
        <id name="id" type="string" length="36">
            <options>
                <option name="comment">UUID</option>
                <option name="collation">utf8mb4_bin</option>
            </options>
        </id>
        <field name="name" type="string" length="191" unique="true" />
        <field name="isPublic" type="boolean"/>
    </entity>
</doctrine-mapping>
