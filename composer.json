{
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "api-platform/doctrine-orm": "^4.0",
        "api-platform/symfony": "^4.0",
        "doctrine/doctrine-bundle": "^3.0",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "elvi/api-client-bundle": "*",
        "elvi/api-log-bundle": "^2.0",
        "elvi/auth-bundle": "^6.0",
        "elvi/health-check-bundle": "^1.0",
        "ramsey/uuid": "^4.6",
        "sentry/sentry-symfony": "^5.0",
        "symfony/asset": "*",
        "symfony/console": "*",
        "symfony/dotenv": "*",
        "symfony/expression-language": "*",
        "symfony/flex": "^2.2",
        "symfony/framework-bundle": "*",
        "symfony/messenger": "*",
        "symfony/monolog-bundle": "^4.0",
        "symfony/property-access": "*",
        "symfony/property-info": "*",
        "symfony/security-bundle": "*",
        "symfony/serializer": "*",
        "symfony/translation": "*",
        "symfony/twig-bundle": "*",
        "symfony/validator": "*",
        "symfony/yaml": "*"
    },
    "require-dev": {
        "codeception/codeception": "^5.0",
        "codeception/module-asserts": "^3.0",
        "codeception/module-doctrine": "^3.1",
        "codeception/module-rest": "^3.2",
        "codeception/module-symfony": "^3.0",
        "elvi/codeception-helpers": "^0.2",
        "mockery/mockery": "^1.6",
        "phpunit/phpcov": "^11.0",
        "psalm/plugin-mockery": "^1.1",
        "roave/security-advisories": "dev-latest",
        "symplify/easy-coding-standard": "^13.0",
        "vimeo/psalm": "^6.0",
        "weirdan/doctrine-psalm-plugin": "^2.9"
    },
    "repositories": [
        {
            "type": "git",
            "url": "git@github.com:vision-group-ag/elvi-auth-bundle.git"
        },
        {
            "type": "git",
            "url": "git@github.com:vision-group-ag/elvi-api-log-bundle.git"
        },
        {
            "type": "git",
            "url": "git@github.com:vision-group-ag/elvi-codeception-helpers.git"
        },
        {
            "type": "git",
            "url": "git@github.com:vision-group-ag/elvi-health-check-bundle.git"
        },
        {
          "type": "git",
          "url": "git@github.com:vision-group-ag/elvi-api-client-bundle.git"
        }
    ],
    "config": {
        "bin-dir": "bin",
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "composer/package-versions-deprecated": true,
            "php-http/discovery": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AppTests\\": "tests/"
        }
    },
    "replace": {
        "paragonie/random_compat": "2.*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php56": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "skeleton:check" : [
            "[ -f ./src/Cli/SkeletonInitCommand.phps ] || echo \"\\e[41;97m     Skeleton initializer already removed     \\e[0m\\n\"",
            "[ -f ./src/Cli/SkeletonDemoRemoveCommand.phps ] || echo \"\\e[41;97m      Skeleton artifacts already removed      \\e[0m\\n\""
        ],
        "skeleton:init" : [
            "@skeleton:check",
            "App\\Cli\\SkeletonInitCommand"
        ],
        "skeleton:demo:remove": [
            "@skeleton:check",
            "App\\Cli\\SkeletonDemoRemoveCommand",
            "rm src/Cli/SkeletonInitCommand.php",
            "rm src/Cli/SkeletonDemoRemoveCommand.php",
            "@auto-scripts"
        ]
    },
    "scripts-descriptions": {
        "skeleton:init": "Initializes a new project from this skeleton",
        "skeleton:demo:remove": "Removes the demo files from this project"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    }
}
